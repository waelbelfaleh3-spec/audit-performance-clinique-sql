-- ============================================================
-- PARTIE 3 : ANALYSES SQL
-- ============================================================


-- ------------------------------------------------------------
-- ANALYSE 1 : Identifier les clients endormis
-- ------------------------------------------------------------
-- PROBLÈME : Qui n'a pas commandé depuis plus de 6 mois ?
-- SOLUTION  : Calculer la date de dernière commande par client
--             et comparer à aujourd'hui avec julianday().
-- ------------------------------------------------------------

SELECT
    c.client_id,
    c.nom,
    c.prenom,
    c.email,
    c.ville,
    MAX(cmd.date_commande)                          AS derniere_commande,
    CAST(julianday('now') - julianday(MAX(cmd.date_commande)) AS INTEGER)
                                                    AS jours_depuis_achat,
    COUNT(DISTINCT cmd.commande_id)                 AS nb_commandes_total,
    ROUND(SUM(cmd.montant_total), 2)                AS ca_total_client
FROM clients c
INNER JOIN commandes cmd ON c.client_id = cmd.client_id
WHERE cmd.statut = 'livree'
GROUP BY c.client_id, c.nom, c.prenom, c.email, c.ville
HAVING jours_depuis_achat > 180
ORDER BY jours_depuis_achat DESC;


-- ------------------------------------------------------------
-- ANALYSE 2 : Segmentation des clients endormis par valeur
-- ------------------------------------------------------------
-- PROBLÈME : On ne relance pas de la même façon un client
--            à 500€ et un client à 30€.
-- SOLUTION  : CASE WHEN pour créer 3 segments de priorité.
-- ------------------------------------------------------------

SELECT
    c.nom,
    c.prenom,
    c.email,
    MAX(cmd.date_commande)                          AS derniere_commande,
    CAST(julianday('now') - julianday(MAX(cmd.date_commande)) AS INTEGER)
                                                    AS jours_inactif,
    ROUND(SUM(cmd.montant_total), 2)                AS ca_total,
    COUNT(DISTINCT cmd.commande_id)                 AS nb_commandes,
    CASE
        WHEN SUM(cmd.montant_total) >= 200          THEN 'PRIORITE HAUTE (VIP)'
        WHEN SUM(cmd.montant_total) >= 80           THEN 'PRIORITE MOYENNE'
        ELSE                                             'PRIORITE BASSE'
    END                                             AS segment_relance
FROM clients c
INNER JOIN commandes cmd ON c.client_id = cmd.client_id
WHERE cmd.statut = 'livree'
GROUP BY c.client_id, c.nom, c.prenom, c.email
HAVING jours_inactif > 180
ORDER BY ca_total DESC;


-- ------------------------------------------------------------
-- ANALYSE 3 : Taux de rétention global de la boutique
-- ------------------------------------------------------------
-- PROBLÈME : Quelle proportion de clients revient acheter ?
-- SOLUTION  : Comparer clients "one-shot" vs clients fidèles.
-- ------------------------------------------------------------

SELECT
    COUNT(DISTINCT CASE WHEN cmd.statut = 'livree' THEN c.client_id END)
                                                    AS clients_total,
    COUNT(DISTINCT CASE
        WHEN cmd.statut = 'livree'
        AND (
            SELECT COUNT(*) FROM commandes c2
            WHERE c2.client_id = c.client_id AND c2.statut = 'livree'
        ) = 1
        THEN c.client_id
    END)                                            AS clients_one_shot,
    COUNT(DISTINCT CASE
        WHEN cmd.statut = 'livree'
        AND (
            SELECT COUNT(*) FROM commandes c2
            WHERE c2.client_id = c.client_id AND c2.statut = 'livree'
        ) >= 2
        THEN c.client_id
    END)                                            AS clients_fideles,
    ROUND(
        COUNT(DISTINCT CASE
            WHEN (SELECT COUNT(*) FROM commandes c2
                  WHERE c2.client_id = c.client_id AND c2.statut = 'livree') >= 2
            THEN c.client_id END) * 100.0 /
        COUNT(DISTINCT CASE WHEN cmd.statut = 'livree' THEN c.client_id END),
        1
    )                                               AS taux_retention_pct
FROM clients c
INNER JOIN commandes cmd ON c.client_id = cmd.client_id;


-- ------------------------------------------------------------
-- ANALYSE 4 : Top produits achetés par les clients endormis
-- ------------------------------------------------------------
-- PROBLÈME : Quels produits cibler dans l'email de relance ?
-- SOLUTION  : Sous-requête dans le FROM pour filtrer
--             uniquement sur les clients endormis.
-- ------------------------------------------------------------

SELECT
    p.nom_produit,
    p.categorie,
    p.prix_unitaire,
    COUNT(DISTINCT lc.commande_id)                  AS nb_fois_achete,
    SUM(lc.quantite)                                AS quantite_totale_vendue
FROM lignes_commande lc
INNER JOIN produits p       ON lc.produit_id  = p.produit_id
INNER JOIN commandes cmd    ON lc.commande_id = cmd.commande_id
INNER JOIN (
    SELECT client_id
    FROM commandes
    WHERE statut = 'livree'
    GROUP BY client_id
    HAVING CAST(julianday('now') - julianday(MAX(date_commande)) AS INTEGER) > 180
) clients_endormis ON cmd.client_id = clients_endormis.client_id
WHERE cmd.statut = 'livree'
GROUP BY p.produit_id, p.nom_produit, p.categorie, p.prix_unitaire
ORDER BY nb_fois_achete DESC;


-- ------------------------------------------------------------
-- ANALYSE 5 : Évolution mensuelle CA + panier moyen
-- ------------------------------------------------------------
-- PROBLÈME : Est-ce qu'on acquiert des clients régulièrement ?
-- SOLUTION  : GROUP BY mois avec COUNT DISTINCT pour éviter
--             de compter plusieurs fois le même client.
-- ------------------------------------------------------------

SELECT
    strftime('%Y-%m', cmd.date_commande)            AS mois,
    COUNT(DISTINCT cmd.client_id)                   AS clients_actifs,
    COUNT(cmd.commande_id)                          AS nb_commandes,
    ROUND(SUM(cmd.montant_total), 2)                AS ca_mensuel,
    ROUND(AVG(cmd.montant_total), 2)                AS panier_moyen
FROM commandes cmd
WHERE cmd.statut = 'livree'
GROUP BY mois
ORDER BY mois ASC;


-- ------------------------------------------------------------
-- ANALYSE 6 : Vue liste de relance exportable CSV
-- ------------------------------------------------------------
-- Cette vue génère directement la liste à exporter pour
-- l'intégrer dans Mailchimp, Brevo ou tout outil d'emailing.
-- ------------------------------------------------------------

CREATE VIEW IF NOT EXISTS vue_liste_relance AS
SELECT
    c.email,
    c.prenom,
    c.nom,
    c.ville,
    MAX(cmd.date_commande)                          AS derniere_commande,
    CAST(julianday('now') - julianday(MAX(cmd.date_commande)) AS INTEGER)
                                                    AS jours_inactif,
    ROUND(SUM(cmd.montant_total), 2)                AS valeur_client,
    CASE
        WHEN SUM(cmd.montant_total) >= 200          THEN 'VIP'
        WHEN SUM(cmd.montant_total) >= 80           THEN 'STANDARD'
        ELSE                                             'FAIBLE'
    END                                             AS segment
FROM clients c
INNER JOIN commandes cmd ON c.client_id = cmd.client_id
WHERE cmd.statut = 'livree'
GROUP BY c.client_id, c.email, c.prenom, c.nom, c.ville
HAVING jours_inactif > 180;

-- Export de la liste
SELECT * FROM vue_liste_relance
ORDER BY valeur_client DESC;
