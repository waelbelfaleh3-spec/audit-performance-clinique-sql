-- CONTEXTE MÉTIER :
--   Une boutique e-commerce constatait une baisse de son CA
--   sans en comprendre la cause. En creusant, on découvre que
--   60% de leurs clients n'ont passé qu'UNE seule commande et
--   ne sont jamais revenus. Ce projet identifie ces clients
--   "endormis" pour les relancer via email marketing ciblé.
--
-- IMPACT ATTENDU :
--   Réactiver 10% des clients endormis = +15% de CA
--   sans dépenser 1€ en acquisition de nouveaux clients.
-- ============================================================


-- ============================================================
-- PARTIE 1 : CRÉATION DES TABLES
-- ============================================================

-- Table des clients
CREATE TABLE clients (
    client_id       INTEGER PRIMARY KEY,
    nom             TEXT    NOT NULL,
    prenom          TEXT    NOT NULL,
    email           TEXT    NOT NULL UNIQUE,
    ville           TEXT,
    date_inscription DATE   NOT NULL
);

-- Table des produits
CREATE TABLE produits (
    produit_id      INTEGER PRIMARY KEY,
    nom_produit     TEXT    NOT NULL,
    categorie       TEXT    NOT NULL,
    prix_unitaire   REAL    NOT NULL
);

-- Table des commandes (une commande = un panier validé)
CREATE TABLE commandes (
    commande_id     INTEGER PRIMARY KEY,
    client_id       INTEGER NOT NULL,
    date_commande   DATE    NOT NULL,
    montant_total   REAL    NOT NULL,
    statut          TEXT    DEFAULT 'livrée',
    FOREIGN KEY (client_id) REFERENCES clients(client_id)
);

-- Table des lignes de commande (le détail de chaque panier)
-- C'est ici qu'on relie commandes et produits (relation N:N)
CREATE TABLE lignes_commande (
    ligne_id        INTEGER PRIMARY KEY,
    commande_id     INTEGER NOT NULL,
    produit_id      INTEGER NOT NULL,
    quantite        INTEGER NOT NULL DEFAULT 1,
    prix_vente      REAL    NOT NULL,
    FOREIGN KEY (commande_id) REFERENCES commandes(commande_id),
    FOREIGN KEY (produit_id)  REFERENCES produits(produit_id)
);


