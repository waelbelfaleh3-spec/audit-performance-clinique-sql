-- ============================================================
-- PARTIE 1 : CRÉATION DES TABLES
-- ============================================================

-- Table des patients
CREATE TABLE patients (
    patient_id   INTEGER PRIMARY KEY,
    nom          TEXT    NOT NULL,
    prenom       TEXT    NOT NULL,
    date_naissance DATE,
    ville        TEXT
);

-- Table des médecins
CREATE TABLE medecins (
    medecin_id   INTEGER PRIMARY KEY,
    nom          TEXT    NOT NULL,
    specialite   TEXT    NOT NULL
);

-- Table des consultations (chaque visite = une ligne)
CREATE TABLE consultations (
    consultation_id  INTEGER PRIMARY KEY,
    patient_id       INTEGER NOT NULL,
    medecin_id       INTEGER NOT NULL,
    date_consultation DATE   NOT NULL,
    montant_du       REAL    NOT NULL,   -- Ce que le patient doit payer
    montant_paye     REAL    DEFAULT 0,  -- Ce qu'il a réellement payé
    FOREIGN KEY (patient_id)  REFERENCES patients(patient_id),
    FOREIGN KEY (medecin_id)  REFERENCES medecins(medecin_id)
);


