-- PARTIE 3 : ANALYSES SQL 
-- ============================================================


-- ------------------------------------------------------------
-- ANALYSE 1 : Liste complète des impayés avec détail patient
-- ------------------------------------------------------------
-- PROBLÈME : La clinique ne sait pas qui doit de l'argent.
-- SOLUTION  : LEFT JOIN entre consultations et patients pour
--             récupérer toutes les consultations, même si le
--             patient a un solde à zéro (impayé total).
-- ------------------------------------------------------------

SELECT
    p.nom                                          AS patient_nom,
    p.prenom                                       AS patient_prenom,
    p.ville,
    c.date_consultation,
    c.montant_du                                   AS montant_facturé,
    c.montant_paye                                 AS montant_payé,
    -- Calcul du reste à payer pour chaque ligne
    (c.montant_du - c.montant_paye)                AS reste_a_payer,
    -- Statut lisible pour filtrage facile
    CASE
        WHEN c.montant_paye = 0               THEN 'IMPAYÉ TOTAL'
        WHEN c.montant_paye < c.montant_du    THEN 'IMPAYÉ PARTIEL'
        ELSE                                       'SOLDÉ'
    END                                            AS statut_paiement
FROM consultations c
-- LEFT JOIN : on garde TOUTES les consultations,
-- même si le patient n'apparaît pas dans une autre table
LEFT JOIN patients p ON c.patient_id = p.patient_id
WHERE c.montant_paye < c.montant_du   -- On ne garde que les impayés
ORDER BY reste_a_payer DESC;          -- Les plus grosses dettes en premier


-- ------------------------------------------------------------
-- ANALYSE 2 : Tableau de bord des impayés par patient
-- ------------------------------------------------------------
-- PROBLÈME : Certains patients ont PLUSIEURS impayés.
--            La clinique veut une vue consolidée par personne.
-- SOLUTION  : GROUP BY + SUM pour agréger par patient.
-- ------------------------------------------------------------

SELECT
    p.nom                                          AS patient_nom,
    p.prenom                                       AS patient_prenom,
    -- Nombre total de consultations du patient
    COUNT(c.consultation_id)                       AS nb_consultations,
    -- Total de ce qu'il a dû payer sur toute la période
    SUM(c.montant_du)                              AS total_facturé,
    -- Total de ce qu'il a réellement payé
    SUM(c.montant_paye)                            AS total_payé,
    -- Solde restant (la vraie dette)
    SUM(c.montant_du - c.montant_paye)             AS solde_impayé
FROM consultations c
LEFT JOIN patients p ON c.patient_id = p.patient_id
GROUP BY p.patient_id, p.nom, p.prenom
-- HAVING filtre sur le résultat du GROUP BY (≠ WHERE qui filtre avant)
HAVING solde_impayé > 0
ORDER BY solde_impayé DESC;


-- ------------------------------------------------------------
-- ANALYSE 3 : Classement des médecins par chiffre d'affaires
-- ------------------------------------------------------------
-- PROBLÈME : La direction veut savoir quels médecins génèrent
--            le plus de revenus ET lesquels ont le plus d'impayés.
-- SOLUTION  : GROUP BY sur medecin_id avec plusieurs métriques.
-- ------------------------------------------------------------

SELECT
    m.nom                                          AS medecin,
    m.specialite,
    COUNT(c.consultation_id)                       AS nb_consultations,
    SUM(c.montant_du)                              AS ca_theorique,
    SUM(c.montant_paye)                            AS ca_reel,
    SUM(c.montant_du - c.montant_paye)             AS montant_impayé,
    -- Taux de recouvrement en % (combien de l'argent dû est réellement encaissé)
    ROUND(
        SUM(c.montant_paye) * 100.0 / SUM(c.montant_du),
        1
    )                                              AS taux_recouvrement_pct
FROM consultations c
LEFT JOIN medecins m ON c.medecin_id = m.medecin_id
GROUP BY m.medecin_id, m.nom, m.specialite
ORDER BY ca_reel DESC;


-- ------------------------------------------------------------
-- ANALYSE 4 : Évolution mensuelle du chiffre d'affaires
-- ------------------------------------------------------------
-- PROBLÈME : Y a-t-il des mois creux ? La clinique croît-elle ?
-- SOLUTION  : GROUP BY sur le mois extrait de la date.
-- ------------------------------------------------------------

SELECT
    -- Extraction du mois depuis la date (format YYYY-MM pour le tri)
    strftime('%Y-%m', c.date_consultation)         AS mois,
    COUNT(c.consultation_id)                       AS nb_consultations,
    SUM(c.montant_du)                              AS ca_facturé,
    SUM(c.montant_paye)                            AS ca_encaissé,
    -- Taux de remplissage mensuel
    ROUND(
        SUM(c.montant_paye) * 100.0 / SUM(c.montant_du),
        1
    )                                              AS taux_encaissement_pct
FROM consultations c
GROUP BY mois
ORDER BY mois ASC;


-- ------------------------------------------------------------
-- ANALYSE 5 
-- ------------------------------------------------------------
-- Une VIEW permet de sauvegarder une requête complexe comme
-- si c'était une table. La direction peut l'appeler à tout moment
-- sans avoir à réécrire le SQL.
-- ------------------------------------------------------------

CREATE VIEW IF NOT EXISTS vue_dashboard_clinique AS
SELECT
    m.nom                                          AS medecin,
    m.specialite,
    strftime('%Y-%m', c.date_consultation)         AS mois,
    COUNT(c.consultation_id)                       AS nb_actes,
    SUM(c.montant_du)                              AS ca_facturé,
    SUM(c.montant_paye)                            AS ca_encaissé,
    SUM(c.montant_du - c.montant_paye)             AS impayés
FROM consultations c
LEFT JOIN medecins m ON c.medecin_id = m.medecin_id
GROUP BY m.medecin_id, mois;

-- Utilisation de la vue 
SELECT * FROM vue_dashboard_clinique
ORDER BY mois DESC, ca_encaissé DESC;
